---
interface AdminBitsImageRowData {
  src: string;
  width: string;
  height: string;
  alt: string;
}

interface Props {
  image: AdminBitsImageRowData;
  index: number;
}

const { image, index } = Astro.props;
const imageNumber = index + 1;
const fieldBase = `images[${index}]`;
const srcPath = `${fieldBase}.src`;
const widthPath = `${fieldBase}.width`;
const heightPath = `${fieldBase}.height`;
---

<div class="admin-row admin-row--muted admin-row--interactive admin-content-image-row" data-admin-content-image-row>
  <div class="admin-content-image-row__head">
    <strong class="admin-content-image-row__title" data-admin-content-image-title>图片 #{imageNumber}</strong>
    <button
      class="admin-btn admin-btn--ghost"
      type="button"
      data-admin-content-image-remove
    >
      移除
    </button>
  </div>
  <div class="admin-content-image-row__grid">
    <div
      class="admin-field admin-content-image-row__field admin-content-image-row__field--src"
      data-field-path={srcPath}
      data-admin-content-image-field="src"
    >
      <span class="admin-field__label">src</span>
      <div class="admin-content-image-row__src-inputs">
        <input
          class="admin-field__control"
          type="text"
          value={image.src}
          spellcheck="false"
          aria-label={`图片 ${imageNumber} src`}
          placeholder="bits/demo.webp 或 https://…"
          data-admin-content-image-src
        />
        <button
          class="admin-btn admin-btn--ghost"
          type="button"
          data-admin-content-image-pick
        >
          选择本地图片
        </button>
      </div>
      <p
        class="admin-content-editor__error"
        data-field-error={srcPath}
        data-admin-content-image-error="src"
        hidden
      ></p>
    </div>
    <label
      class="admin-field admin-content-image-row__field"
      data-field-path={widthPath}
      data-admin-content-image-field="width"
    >
      <span class="admin-field__label">width</span>
      <input class="admin-field__control" type="number" min="1" step="1" value={image.width} data-admin-content-image-width />
      <p
        class="admin-content-editor__error"
        data-field-error={widthPath}
        data-admin-content-image-error="width"
        hidden
      ></p>
    </label>
    <label
      class="admin-field admin-content-image-row__field"
      data-field-path={heightPath}
      data-admin-content-image-field="height"
    >
      <span class="admin-field__label">height</span>
      <input class="admin-field__control" type="number" min="1" step="1" value={image.height} data-admin-content-image-height />
      <p
        class="admin-content-editor__error"
        data-field-error={heightPath}
        data-admin-content-image-error="height"
        hidden
      ></p>
    </label>
    <label class="admin-field admin-content-image-row__field admin-content-image-row__field--alt">
      <span class="admin-field__label">alt（可选）</span>
      <input class="admin-field__control" type="text" value={image.alt} data-admin-content-image-alt />
    </label>
  </div>
  <div class="admin-content-image-row__footer">
    <p class="admin-content-image-row__meta" data-admin-content-image-meta>等待选择图片或输入路径</p>
    <div class="admin-content-image-row__preview" data-admin-content-image-preview hidden>
      <img alt="" loading="lazy" decoding="async" data-admin-content-image-preview-img />
    </div>
  </div>
</div>
